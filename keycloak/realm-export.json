{
  "realm": "seat-reservation",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "ssoSessionMaxLifespan": 7776000,
  "ssoSessionIdleTimeout": 7776000,
  "accessTokenLifespan": 300,
  "refreshTokenMaxReuse": 0,
  "offlineSessionMaxLifespan": 7776000,
  "clients": [
    {
      "clientId": "seat-reservation-app",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4200/*"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Regular user who can view and book seats"
      },
      {
        "name": "ADMIN",
        "description": "Administrator who can reconcile payments and view audit logs"
      }
    ]
  },
  "users": [
    {
      "username": "user@tpthinh.com",
      "enabled": true,
      "email": "user@tpthinh.com",
      "firstName": "Regular",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "User1234!",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"]
    },
    {
      "username": "admin@tpthinh.com",
      "enabled": true,
      "email": "admin@tpthinh.com",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Admin1234!",
          "temporary": false
        }
      ],
      "realmRoles": ["USER", "ADMIN"]
    }
  ]
}
