# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=seatreservation
DB_USER=seat
DB_PASS=seat

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Keycloak Configuration
# KEYCLOAK_ISSUER must match the issuer in the JWT token (what browser sees)
KEYCLOAK_ISSUER=http://localhost:8180/realms/seat-reservation
# KEYCLOAK_JWK_SET_URI is where backend fetches public keys (internal Docker network)
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/seat-reservation/protocol/openid-connect/certs
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Backend Configuration
BACKEND_URL=http://backend:8080
WEBHOOK_SECRET=change-me-in-production

# Mock Payment Service Configuration
MOCK_PAYMENT_URL=http://mock-payment-service:9090
