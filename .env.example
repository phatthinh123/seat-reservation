# =====================================================
# Seat Reservation — Environment Variables
# =====================================================
# Copy this file to .env and fill in any values
# that differ from the defaults shown here.
# =====================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seatreservation
DB_USER=seat
DB_PASS=seat

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Keycloak ---
# The issuer URI of the Keycloak realm used to validate JWTs.
# In Docker Compose this is http://keycloak:8080/realms/seat-reservation
# For local (non-Docker) development: http://localhost:8180/realms/seat-reservation
KEYCLOAK_ISSUER=http://localhost:8180/realms/seat-reservation

# --- Webhook ---
# Shared HMAC-SHA256 secret between mock-payment-service and backend.
# The mock payment service signs every webhook with this secret.
# The backend verifies the X-Signature header against this secret.
WEBHOOK_SECRET=local-dev-secret

# --- Mock Payment Service ---
# URL the mock payment service will POST webhooks to
WEBHOOK_URL=http://localhost:8080/api/webhooks/payment
# Base URL of the mock payment service (called by backend for reconciliation)
MOCK_PAYMENT_URL=http://localhost:9090

# --- Backend ---
# Public base URL of the backend (used for callback URLs sent to payment service)
BACKEND_URL=http://localhost:8080
